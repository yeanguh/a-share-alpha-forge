.DS_Store

# Python bytecode and caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.idea/
.vscode/
.playwright-cli/

# Local virtual environment and uv/runtime caches
.venv/
.uv-cache/

# Local generated data
tmp/
local/stock_pools/*/cache/

# 全局 ~/.gitignore 忽略了 .agents，本项目 skill 链路需纳入版本控制，显式取消忽略
!.agents/
!.agents/**
